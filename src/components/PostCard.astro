---
import { formatPostDate } from "../lib/posts";

interface EntryData {
  title: string;
  description: string;
  date: Date;
  ogImage: string;
  keywords: string[];
  lang: "pt-BR" | "en-US";
}

interface Props {
  href: string;
  data: EntryData;
  variant?: "lead" | "stacked" | "list";
  ctaLabel?: string;
}

const { href, data, variant = "list", ctaLabel } = Astro.props;
const defaultCta = data.lang === "en-US" ? "Read article" : "Ler publicação";
const cta = ctaLabel ?? defaultCta;
---

<article class:list={["post-card", `post-card--${variant}`]}>
  {variant === "lead" && (
    <a class="post-card__media" href={href}>
      <img src={data.ogImage} alt={data.title} loading="lazy" />
    </a>
  )}

  <div class="post-card__body">
    <div class="post-card__meta">
      <span>{formatPostDate(data.date, data.lang)}</span>
      <span>{data.keywords[0]}</span>
    </div>

    <h3 class="post-card__title">
      <a href={href}>{data.title}</a>
    </h3>

    <p class="post-card__description">{data.description}</p>

    <a class="post-card__cta" href={href}>
      {cta}
    </a>
  </div>
</article>
