---
import { profile } from "../lib/about-content";

interface Props {
  lang?: "pt-BR" | "en-US";
}

const { lang = "pt-BR" } = Astro.props;
const year = new Date().getFullYear();

const copy =
  lang === "en-US"
    ? {
        eyebrow: "Contact & digital presence",
        title: "Connections focused on architecture, security, and technical leadership.",
        navLabel: "Contact and social links",
        bar: `© ${year} Fábio Monreal · technical authority hub`
      }
    : {
        eyebrow: "Contato e presença digital",
        title: "Conexões com foco em arquitetura, segurança e liderança técnica.",
        navLabel: "Contato e redes",
        bar: `© ${year} Fábio Monreal · hub de autoridade técnica`
      };
---

<footer class="site-footer" id="contato">
  <div class="shell site-footer__shell">
    <div class="site-footer__inner">
      <div class="site-footer__intro">
        <p class="eyebrow">{copy.eyebrow}</p>
        <h2 class="footer-title">{copy.title}</h2>
      </div>

      <nav class="footer-links" aria-label={copy.navLabel}>
        <a href={profile.linkedin} target="_blank" rel="noreferrer noopener">LinkedIn</a>
        <a href={profile.github} target="_blank" rel="noreferrer noopener">GitHub</a>
        <a href={profile.credly} target="_blank" rel="noreferrer noopener">Credly</a>
        <a href={profile.medium} target="_blank" rel="noreferrer noopener">Medium</a>
        <a href={`mailto:${profile.email}`}>{profile.email}</a>
      </nav>
    </div>
    <div class="site-footer__bar">
      <p class="site-footer__legal">{copy.bar}</p>
    </div>
  </div>
</footer>
