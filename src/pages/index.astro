---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import { aboutContent, profile } from "../lib/about-content";
import { postPublicPath, postsByLang } from "../lib/posts";
import { DEFAULT_OG_IMAGE, SITE_DESCRIPTION, SITE_TITLE } from "../lib/site";

const all = await getCollection("posts");
const posts = postsByLang(all, "pt-BR");

const [featured, ...rest] = posts;
const secondary = rest.slice(0, 2);
const recentForTopics = posts.slice(0, 3);
const topicChips = [...new Set(recentForTopics.flatMap((p) => p.data.keywords))].slice(0, 6);

const recentTitles = recentForTopics.map((p) => p.data.title);
const destaqueSubtitle =
  recentTitles.length > 0
    ? `Leia primeiro o que acaba de entrar no arquivo: ${recentTitles.join(" · ")}.`
    : "Novos textos aparecem aqui assim que forem publicados.";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: SITE_TITLE,
  url: "https://fabiomonreal.com/",
  description: SITE_DESCRIPTION,
  author: {
    "@type": "Person",
    name: profile.name,
    url: "https://fabiomonreal.com/sobre/",
    sameAs: [profile.linkedin, profile.github, profile.medium, profile.devto]
  }
};
---

<BaseLayout
  title={SITE_TITLE}
  description={SITE_DESCRIPTION}
  ogImage={DEFAULT_OG_IMAGE}
  keywords={[
    "arquiteto cloud",
    "multi-cloud",
    "cibersegurança",
    "FinOps",
    "GenAI soberana"
  ]}
  schema={schema}
  currentPath="/"
>
  <main class="landing-main">
    <section class="hero hero--viewport">
      <div class="shell hero__shell">
        <div class="hero__wrap">
          <div class="hero__intro">
            <p class="eyebrow">Hub de Autoridade Técnica</p>
            <p class="hero__given">Fábio</p>
            <h1 class="hero__title">Monreal</h1>
            <p class="hero__copy">
              {profile.role}. Publicações técnicas, visão executiva e arquitetura de alta criticidade
              com foco em cloud, segurança, FinOps, SRE e soberania de dados.
            </p>

            <div class="hero__actions">
              <a class="button button--primary" href="/sobre/">Sobre</a>
              <a class="button button--ghost" href="/posts/">Ver publicações</a>
            </div>
          </div>

          <aside class="hero-panel">
            <p class="eyebrow">Áreas de atuação</p>
            <p class="section-copy">{aboutContent.pt.intro}</p>
            <ul class="hero-panel__list">
              <li>Multi-Cloud</li>
              <li>Segurança</li>
              <li>FinOps</li>
              <li>Incident Response</li>
              <li>GenAI Soberana</li>
              <li>SRE</li>
            </ul>
          </aside>
        </div>
      </div>
      <div class="hero__fade" aria-hidden="true"></div>
      <a class="hero-scroll" href="#destaques" aria-label="Ir para publicações em destaque">
        <span class="hero-scroll__label">Explorar</span>
        <svg class="hero-scroll__icon" width="22" height="22" viewBox="0 0 24 24" aria-hidden="true">
          <path
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M6 9l6 6 6-6"></path>
        </svg>
      </a>
    </section>

    <div class="landing-separator" aria-hidden="true"></div>

    <section class="section section--tight section--band" id="destaques">
      <div class="shell">
        <div class="page-intro">
          <p class="eyebrow">Publicações em destaque</p>
          <h2 class="section-title">O que há de novo no arquivo</h2>
          <p class="section-copy">
            {destaqueSubtitle} Textos em português; a versão em inglês está na{" "}
            <a class="subtle-link" href="/en/">página inicial EN</a> e no{" "}
            <a class="subtle-link" href="/en/posts/">arquivo em inglês</a>.
          </p>
        </div>

        <div class="insight-grid section--tight">
          {featured && (
            <PostCard href={postPublicPath(featured)} data={featured.data} variant="lead" />
          )}

          <div class="stack-grid">
            {secondary.map((post) => (
              <PostCard href={postPublicPath(post)} data={post.data} variant="stacked" />
            ))}
          </div>
        </div>

        <div class="button-row">
          <a class="subtle-link" href="/posts/">Ver todas as publicações</a>
        </div>
      </div>
    </section>

    <section class="section section--surface">
      <div class="shell summary-grid">
        <div class="content-card">
          <p class="eyebrow">Resumo executivo</p>
          <h2 class="section-title">Arquitetura, segurança e continuidade com viés executivo.</h2>
          {aboutContent.pt.summary.slice(0, 2).map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>

        <div class="content-card">
          <p class="eyebrow">Temas em foco no arquivo recente</p>
          <h2 class="section-title">Palavras-chave dos textos mais novos</h2>
          <p class="section-copy">
            Palavras-chave dos três artigos em português mais recentes no arquivo.
          </p>
          <ul class="list-reset topic-chips">
            {topicChips.map((topic) => (
              <li>{topic}</li>
            ))}
          </ul>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
