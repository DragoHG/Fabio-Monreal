---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PostLayout from "../../../layouts/PostLayout.astro";
import { buildPostPageContext } from "../../../lib/post-page";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts
    .filter((post) => post.data.lang === "en-US")
    .map((post) => ({
      params: { slug: post.id },
      props: { post }
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const allPosts = await getCollection("posts");
const ctx = buildPostPageContext(post, allPosts, "en-US");
---

<BaseLayout
  title={`${post.data.title} | Fábio Monreal`}
  description={post.data.description}
  canonicalURL={post.data.canonicalURL}
  ogImage={post.data.ogImage}
  ogImageAlt={post.data.ogImageAlt}
  ogImageWidth={post.data.ogImageWidth}
  ogImageHeight={post.data.ogImageHeight}
  keywords={post.data.keywords}
  type="article"
  publishedTime={post.data.date.toISOString()}
  schema={ctx.schema}
  currentPath={Astro.url.pathname}
  lang="en-US"
  hreflangAlternates={ctx.hreflangAlternates}
  xDefaultHref={ctx.xDefaultHref}
  ogLocaleAlternate={ctx.ogLocaleAlternate}
  localePair={ctx.localePair}
>
  <PostLayout
    lang="en-US"
    title={post.data.title}
    description={post.data.description}
    date={post.data.date}
    keywords={post.data.keywords}
    translationLink={ctx.translationLink}
  >
    <Content />
  </PostLayout>
</BaseLayout>
